# Example environment configuration for RTCD Backend

# ===================
# Database
# ===================
# PostgreSQL connection string, e.g.:
# postgresql+psycopg2://user:password@localhost:5432/rtcd
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/rtcd

# ===================
# Google OAuth 2.0
# ===================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ===================
# JWT
# ===================
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ===================
# App settings
# ===================
APP_NAME=RTCD
APP_VERSION=1.0.0
DEBUG=true

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================
# WebSocket settings
# ===================
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS_PER_DOCUMENT=50

